-- Whitelist Tab
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
local function refreshWhitelistTab()
    for _, child in ipairs(whitelistTab:GetChildren()) do
        if child:IsA("GuiObject") then child:Destroy() end
    end
    local y = 0
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == player then continue end
        local nameLabel = Instance.new("TextLabel", whitelistTab)
        nameLabel.Size = UDim2.new(0.7, 0, 0, 30)
        nameLabel.Position = UDim2.new(0, 0, 0, y)
        nameLabel.BackgroundTransparency = 1
        nameLabel.Text = plr.Name
        nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        nameLabel.TextSize = 14
        nameLabel.Font = Enum.Font.Gotham
        nameLabel.TextXAlignment = Enum.TextXAlignment.Left

        local toggleBtn = Instance.new("TextButton", whitelistTab)
        toggleBtn.Size = UDim2.new(0.3, 0, 0, 30)
        toggleBtn.Position = UDim2.new(0.7, 0, 0, y)
        toggleBtn.BackgroundColor3 = Whitelist[plr.Name] and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(200, 0, 0)
        toggleBtn.Text = Whitelist[plr.Name] and "Whitelisted" or "Lockable"
        toggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        toggleBtn.TextSize = 13
        toggleBtn.Font = Enum.Font.GothamSemibold
        Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(0, 6)

        local capturedPlr = plr
        toggleBtn.MouseButton1Click:Connect(function()
            Whitelist[capturedPlr.Name] = not Whitelist[capturedPlr.Name]
            toggleBtn.BackgroundColor3 = Whitelist[capturedPlr.Name] and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(200, 0, 0)
            toggleBtn.Text = Whitelist[capturedPlr.Name] and "Whitelisted" or "Lockable"
        end)
        y = y + 36
    end
    whitelistTab.CanvasSize = UDim2.new(0, 0, 0, math.max(y, 1))
end

for _, plr in ipairs(Players:GetPlayers()) do
    if plr ~= player then
        createESP(plr)
        Whitelist[plr.Name] = false
    end
end
refreshWhitelistTab()

Players.PlayerAdded:Connect(function(plr)
    if plr ~= player then
        createESP(plr)
        Whitelist[plr.Name] = false
        refreshWhitelistTab()
    end
end)

Players.PlayerRemoving:Connect(function(plr)
    if espDrawings[plr] then
        for k, v in pairs(espDrawings[plr]) do
            v:Remove()
        end
        espDrawings[plr] = nil
    end
    Whitelist[plr.Name] = nil
    refreshWhitelistTab()
end)

