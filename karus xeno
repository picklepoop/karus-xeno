-- Sliders – FIXED camlock label (only this part changed)
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
local function setupSlider(bg, fill, knob, label, setter, maxVal, labelFormat)
    local draggingS = false
    bg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            draggingS = true
        end
    end)
    bg.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            draggingS = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if not draggingS then return end
        if input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch then return end
        local pct = math.clamp((input.Position.X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
        fill.Size = UDim2.new(pct, 0, 1, 0)
        knob.Position = UDim2.new(pct, -8, 0.5, -8)
        local value = maxVal and math.floor(pct * maxVal) or pct
        setter(value)
        -- FIXED LINE: always format as percentage when maxVal is nil
        if maxVal == nil then
            label.Text = string.format("Camlock Strength: %.0f%%", pct * 100)
        else
            label.Text = string.format(labelFormat or "%d", value)
        end
    end)
end

setupSlider(strBg, strFill, strKnob, strLabel, function(v) CamlockSettings.Strength = v end, nil, "Camlock Strength: %.0f%%")
