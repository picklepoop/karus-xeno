    btn.TextColor3 = Color3.fromRGB(255,255,255)
    btn.TextSize = 13
    btn.Font = Enum.Font.GothamSemibold
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    btn.MouseButton1Click:Connect(function()
        CamlockChecks[varName] = not CamlockChecks[varName]
        btn.BackgroundColor3 = CamlockChecks[varName] and Color3.fromRGB(60,160,100) or Color3.fromRGB(90,50,50)
        btn.Text = name .. ": " .. (CamlockChecks[varName] and "ON" or "OFF")
    end)
    yMain = yMain + 36
end

