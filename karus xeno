-- Status
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
local function updateStatus()
    local lockStr = CamlockSettings.Locked
        and ("Locked: " .. (CamlockSettings.LockedPlayer and CamlockSettings.LockedPlayer.Name or "None"))
        or "Unlocked"
    status.Text = lockStr
        .. " | Speed: " .. (isSpeedEnabled and "ON" or "OFF")
        .. " | Fly: " .. (FlySettings.Enabled and "ON" or "OFF")
        .. " | Strafe: " .. (StrafeSettings.Enabled and "ON" or "OFF")
        .. " | Noclip: " .. (NoclipSettings.Enabled and "ON" or "OFF")
        .. " | ESP: " .. (ESPSettings.Enabled and "ON" or "OFF")
    status.TextColor3 = CamlockSettings.Locked and Color3.fromRGB(100,255,140) or Color3.fromRGB(255,140,100)
    camlockBtn.BackgroundColor3 = CamlockSettings.Locked and Color3.fromRGB(60,160,100) or Color3.fromRGB(90,50,50)
