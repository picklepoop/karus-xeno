-- Loops
RunService.Heartbeat:Connect(function(dt)
    updateCFrameSpeed(dt)
    if StrafeSettings.Enabled and CamlockSettings.LockedTarget and CamlockSettings.LockedTarget.Parent then
        strafeHAngle += StrafeSettings.HSpeed * dt
        strafeVAngle += StrafeSettings.VSpeed * dt
        local targetPos = CamlockSettings.LockedTarget.Position
        local offset = Vector3.new(
            math.cos(strafeHAngle) * StrafeSettings.Radius,
            math.sin(strafeVAngle) * StrafeSettings.VSpeed,
            math.sin(strafeHAngle) * StrafeSettings.Radius
        )
        local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if root then root.CFrame = CFrame.new(targetPos + offset, targetPos) end
    end
end)

RunService.RenderStepped:Connect(function()
    if CamlockSettings.Locked and CamlockSettings.LockedPlayer and CamlockSettings.LockedTarget then
        if not CamlockSettings.LockedTarget.Parent then
            CamlockSettings.LockedTarget = nil
            return
        end
        local targetPos = CamlockSettings.LockedTarget.Position
        local newCFrame = CFrame.lookAt(camera.CFrame.Position, targetPos)
        camera.CFrame = camera.CFrame:Lerp(newCFrame, CamlockSettings.Strength)
    end
end)

