-- Keybind Changing
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
local changingFor = nil
local allChangeBtns = {camChangeBtn, speedChangeBtn, flyChangeBtn, strafeChangeBtn, noclipChangeBtn, espChangeBtn}

local function resetChangeBtns()
    for _, b in ipairs(allChangeBtns) do
        b.Text = "Change"
        b.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
    end
end

local function startChangeKey(forWhat, btn)
    changingFor = forWhat
    btn.Text = "Press key... (ESC = cancel)"
    btn.BackgroundColor3 = Color3.fromRGB(90, 60, 120)
end

camChangeBtn.MouseButton1Click:Connect(function()    startChangeKey("Camlock", camChangeBtn) end)
speedChangeBtn.MouseButton1Click:Connect(function()  startChangeKey("Speed",   speedChangeBtn) end)
flyChangeBtn.MouseButton1Click:Connect(function()    startChangeKey("Fly",     flyChangeBtn) end)
strafeChangeBtn.MouseButton1Click:Connect(function() startChangeKey("Strafe",  strafeChangeBtn) end)
noclipChangeBtn.MouseButton1Click:Connect(function() startChangeKey("Noclip",  noclipChangeBtn) end)
espChangeBtn.MouseButton1Click:Connect(function()    startChangeKey("ESP",     espChangeBtn) end)

-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
-- Input Handling
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end

    -- Keybind capture
    if changingFor then
        if input.KeyCode == Enum.KeyCode.Escape then
            changingFor = nil
            resetChangeBtns()
        elseif input.KeyCode ~= Enum.KeyCode.Unknown then
            local key = input.KeyCode
            local keyName = key.Name
            if     changingFor == "Camlock" then CamlockSettings.Keybind = key camKeyLabel.Text = "Camlock Key: "..keyName
            elseif changingFor == "Speed"   then getgenv().walkSpeedSettings.Activation.WalkSpeedToggleKey = key speedKeyLabel.Text = "Speed Key: "..keyName
            elseif changingFor == "Fly"     then FlySettings.Keybind = key flyKeyLabel.Text = "Fly Key: "..keyName
            elseif changingFor == "Strafe"  then StrafeSettings.Keybind = key strafeKeyLabel.Text = "Strafe Key: "..keyName
            elseif changingFor == "Noclip"  then NoclipSettings.Keybind = key noclipKeyLabel.Text = "Noclip Key: "..keyName
            elseif changingFor == "ESP"     then ESPSettings.Keybind = key espKeyLabel.Text = "ESP Key: "..keyName
            end
            changingFor = nil
            resetChangeBtns()
        end
        return
    end

    -- Camlock
    if input.KeyCode == CamlockSettings.Keybind then
        if CamlockSettings.Locked then
            CamlockSettings.Locked = false
            CamlockSettings.LockedPlayer = nil
            CamlockSettings.LockedTarget = nil
            if CamlockSettings.RespawnConn then CamlockSettings.RespawnConn:Disconnect() CamlockSettings.RespawnConn = nil end
            StrafeSettings.Enabled = false
        else
            local mousePos = UserInputService:GetMouseLocation()
            local closest, minDist = nil, CamlockSettings.FOV
            for _, plr in Players:GetPlayers() do
                if plr == player or not plr.Character then continue end
                local head = plr.Character:FindFirstChild("Head")
                if not head then continue end
                if not isValidForCamlock(plr, plr.Character) then continue end
                if not hasLineOfSightCamlock(head) then continue end
                local screen, onScreen = camera:WorldToViewportPoint(head.Position)
                if not onScreen then continue end
                local dist = (Vector2.new(screen.X, screen.Y) - mousePos).Magnitude
                if dist < minDist then minDist = dist closest = plr end
            end
            if closest then
                CamlockSettings.Locked = true
                CamlockSettings.LockedPlayer = closest
                CamlockSettings.LockedTarget = closest.Character.Head
                if CamlockSettings.RespawnConn then CamlockSettings.RespawnConn:Disconnect() end
                CamlockSettings.RespawnConn = closest.CharacterAdded:Connect(function(newChar)
                    CamlockSettings.LockedTarget = nil
                    local newHead = newChar:WaitForChild("Head", 10)
                    local hum = newChar:WaitForChild("Humanoid", 10)
                    if not newHead or not hum then return end
                    local waited = 0
                    while waited < 8 do
                        hum = newChar:FindFirstChildOfClass("Humanoid")
                        if hum and hum.Health > 0 then break end
                        task.wait(0.05)
                        waited += 0.05
                    end
                    if CamlockSettings.Locked and CamlockSettings.LockedPlayer == closest then
                        local h = newChar:FindFirstChild("Head")
                        if h then CamlockSettings.LockedTarget = h end
                    end
                end)
            end
        end
        updateStatus()
    end

    -- Speed
    if input.KeyCode == getgenv().walkSpeedSettings.Activation.WalkSpeedToggleKey then
        isSpeedEnabled = not isSpeedEnabled
        updateStatus()
    end

    -- Fly
    if input.KeyCode == FlySettings.Keybind then
        FlySettings.Enabled = not FlySettings.Enabled
        if FlySettings.Enabled then startFly() else stopFly() end
        updateStatus()
    end

    -- Strafe
    if input.KeyCode == StrafeSettings.Keybind then
        if not CamlockSettings.Locked then return end
        StrafeSettings.Enabled = not StrafeSettings.Enabled
        NoclipSettings.Enabled = StrafeSettings.Enabled
        updateNoclip()
        updateStatus()
    end

    -- Noclip
    if input.KeyCode == NoclipSettings.Keybind then
        NoclipSettings.Enabled = not NoclipSettings.Enabled
        updateNoclip()
        updateStatus()
    end

    -- ESP
    if input.KeyCode == ESPSettings.Keybind then
        ESPSettings.Enabled = not ESPSettings.Enabled
        updateStatus()
    end
end)

