-- Enhanced ESP
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
local espDrawings = {}

local function createESP(plr)
    if plr == player or espDrawings[plr] then return end
    local box = Drawing.new("Square")
    box.Thickness = 2
    box.Filled = false
    box.Transparency = 1
    box.Color = Color3.fromRGB(255, 50, 50)

    local name = Drawing.new("Text")
    name.Size = 14
    name.Center = true
    name.Outline = true
    name.Color = Color3.fromRGB(255, 255, 255)
    name.Text = plr.Name

    local healthBG = Drawing.new("Line")
    healthBG.Thickness = 3
    healthBG.Color = Color3.fromRGB(40, 40, 40)
    healthBG.Transparency = 1

    local healthBar = Drawing.new("Line")
    healthBar.Thickness = 2
    healthBar.Color = Color3.fromRGB(0, 255, 0)
    healthBar.Transparency = 1

    local distanceTxt = Drawing.new("Text")
    distanceTxt.Size = 13
    distanceTxt.Center = true
    distanceTxt.Outline = true
    distanceTxt.Color = Color3.fromRGB(220, 220, 170)

    local ammoTxt = Drawing.new("Text")
    ammoTxt.Size = 13
    ammoTxt.Center = true
    ammoTxt.Outline = true
    ammoTxt.Color = Color3.fromRGB(180, 220, 255)

    espDrawings[plr] = {
        Box = box,
        Name = name,
        HealthBG = healthBG,
        HealthBar = healthBar,
        Distance = distanceTxt,
        Ammo = ammoTxt
    }
end

local function updateESP()
    for plr, drawings in pairs(espDrawings) do
        local char = plr.Character
        if not ESPSettings.Enabled or not char or not char:FindFirstChild("HumanoidRootPart") or not char:FindFirstChild("Head") then
            for _, obj in pairs(drawings) do obj.Visible = false end
            continue
        end
        if not isValidForESP(plr, char) or not hasLineOfSightESP(char.Head) then
            for _, obj in pairs(drawings) do obj.Visible = false end
            continue
        end
        local root = char.HumanoidRootPart
        local head = char.Head
        local hum = char:FindFirstChildOfClass("Humanoid")
        local rootPos, onScreen = camera:WorldToViewportPoint(root.Position)
        local headPos = camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
        local legPos = camera:WorldToViewportPoint(root.Position - Vector3.new(0, 3, 0))
        if not onScreen then
            for _, obj in pairs(drawings) do obj.Visible = false end
            continue
        end
        local height = math.abs(headPos.Y - legPos.Y)
        local width = height * 0.5
        -- Box
        drawings.Box.Size = Vector2.new(width, height)
        drawings.Box.Position = Vector2.new(rootPos.X - width/2, rootPos.Y - height/2)
        drawings.Box.Visible = ESPSettings.ShowBox
        -- Name
        drawings.Name.Position = Vector2.new(rootPos.X, rootPos.Y - height/2 - 16)
        drawings.Name.Visible = ESPSettings.ShowName
        -- Health Bar
        if ESPSettings.ShowHealthBar and hum then
            local hpRatio = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
            local barHeight = height * hpRatio
            drawings.HealthBG.From = Vector2.new(rootPos.X - width/2 - 6, rootPos.Y - height/2)
            drawings.HealthBG.To = Vector2.new(rootPos.X - width/2 - 6, rootPos.Y + height/2)
            drawings.HealthBG.Visible = true
            drawings.HealthBar.From = Vector2.new(rootPos.X - width/2 - 6, rootPos.Y + height/2)
            drawings.HealthBar.To = Vector2.new(rootPos.X - width/2 - 6, rootPos.Y + height/2 - barHeight)
            drawings.HealthBar.Color = Color3.fromHSV(hpRatio * 0.3, 0.9, 0.9)
            drawings.HealthBar.Visible = true
        else
            drawings.HealthBG.Visible = false
            drawings.HealthBar.Visible = false
        end
        -- Distance
        if ESPSettings.ShowDistance then
            local myRoot = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            local dist = myRoot and (root.Position - myRoot.Position).Magnitude or 0
            drawings.Distance.Text = string.format("%.0f studs", dist)
            drawings.Distance.Position = Vector2.new(rootPos.X, rootPos.Y + height/2 + 4)
            drawings.Distance.Visible = true
        else
            drawings.Distance.Visible = false
        end
        -- Ammo
        if ESPSettings.ShowAmmo then
            local tool = char:FindFirstChildWhichIsA("Tool")
            local ammoStr = "No gun"
            if tool then
                local ammo = tool:FindFirstChild("Ammo") or tool:FindFirstChild("CurrentAmmo") or tool:FindFirstChild("Bullets")
                if ammo and (ammo:IsA("IntValue") or ammo:IsA("NumberValue")) then
                    ammoStr = tostring(ammo.Value) .. " ammo"
                end
            end
            drawings.Ammo.Text = ammoStr
            drawings.Ammo.Position = Vector2.new(rootPos.X, rootPos.Y + height/2 + 20)
            drawings.Ammo.Visible = true
        else
            drawings.Ammo.Visible = false
        end
    end
end

RunService.RenderStepped:Connect(updateESP)

