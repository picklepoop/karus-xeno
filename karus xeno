-- Validation
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
local function isValidForCamlock(plr, char)
    if not char then return false end
    if Whitelist[plr.Name] then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return false end
    if CamlockChecks.DeathCheck and hum.Health <= 0 then return false end
    if CamlockChecks.KnockedCheck and hum.Health <= 5 then return false end
    if CamlockChecks.TeamCheck and plr.Team and player.Team and plr.Team == player.Team then return false end
    return true
end

local function isValidForESP(plr, char)
    if not char then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return false end
    if ESPChecks.DeathCheck and hum.Health <= 0 then return false end
    if ESPChecks.KnockedCheck and hum.Health <= 5 then return false end
    if ESPChecks.TeamCheck and plr.Team and player.Team and plr.Team == player.Team then return false end
    return true
end

local function hasLineOfSightCamlock(targetHead)
    if not CamlockChecks.WallCheck then return true end
    local origin = camera.CFrame.Position
    local direction = targetHead.Position - origin
    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {player.Character or {}}
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.IgnoreWater = true
    local result = workspace:Raycast(origin, direction, params)
    return result and result.Instance and result.Instance:IsDescendantOf(targetHead.Parent)
end

local function hasLineOfSightESP(targetHead)
    if not ESPChecks.WallCheck then return true end
    local origin = camera.CFrame.Position
    local direction = targetHead.Position - origin
    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {player.Character or {}}
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.IgnoreWater = true
    local result = workspace:Raycast(origin, direction, params)
    return result and result.Instance and result.Instance:IsDescendantOf(targetHead.Parent)
end

